# Required for Groq AI summaries.
GROQ_API_KEY=your_groq_api_key_here

# Keep model configurable because hosted model availability can change.
GROQ_MODEL=llama-3.1-8b-instant

APP_ENV=development
LOG_LEVEL=INFO

# SEC asks automated tools to identify themselves.
# Example: Ankush Porwal your.email@example.com
SEC_USER_AGENT=AISECFilingAnalyzer your.email@example.com
